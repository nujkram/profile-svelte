		"typescript": "^5.5.0",
		"vite": "^6.0.0"
	},
	"type": "module",
	"dependencies": {
		"bcryptjs": "^2.4.3",
		"crypto-js": "^4.1.1",
		"date-fns": "^2.29.3",
		"dotenv": "^16.0.3",
		"gsap": "^3.14.2",
		"mongodb": "^6.21.0",
		"pdfkit": "^0.19.1",
		"xstate": "^4.34.0"
	}
